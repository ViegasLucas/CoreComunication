PORT=3001
NODE_ENV=development

# CORS: Domínio do frontend (Vercel). Em dev, deixe vazio ou use *
# Exemplo de produção: ALLOWED_ORIGIN=https://seu-app.vercel.app
ALLOWED_ORIGIN=http://localhost:5176

# Service Account do Firebase Admin SDK
# Opção 1 (Produção / Vercel): Cole o conteúdo do serviceAccountKey.json minificado aqui
FIREBASE_SERVICE_ACCOUNT_KEY=

# Opção 2 (Desenvolvimento local): deixe vazio e coloque o arquivo serviceAccountKey.json
# na raiz da pasta /backend (já ignorado pelo .gitignore)

# Google Gemini API Key
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=SUA_CHAVE_AQUI

# Modelo Gemini a usar (opcional). Padrão: gemini-2.0-flash
GEMINI_MODEL=gemini-3.1-flash-lite

# Comportamento LGPD: se true, dados sensíveis serão redigidos automaticamente antes do envio
# Se false (padrão), a requisição será recusada quando houver dados sensíveis
LGPD_REDACT=false
